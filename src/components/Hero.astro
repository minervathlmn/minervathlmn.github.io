<style>
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: clamp(3rem, 10vw, 7rem) var(--section-pad) clamp(4rem, 8vw, 6rem);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--maroon-soft);
    margin: 0 0 1rem;
  }

  .name {
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 0.95;
    margin: 0 0 1.5rem;
    font-size: clamp(3.5rem, 10vw, 7.5rem);
  }

  .name-primary {
    display: block;
    color: var(--maroon);
  }

  .name-accent {
    display: block;
    font-style: italic;
    font-weight: 500;
    color: var(--maroon-soft);
  }

  .role {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--ink);
    opacity: 0.75;
    margin: 0 0 0.5rem;
  }

  .tagline {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: var(--ink);
    margin: 0 0 2.5rem;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.85rem 1.5rem;
    border-radius: 6px;
    border: 1px solid transparent;
    transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.1s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-fill {
    background: var(--green);
    color: var(--beige);
  }
  .btn-fill:hover {
    background: var(--green-dark);
  }

  .btn-outline-strong {
    border-color: var(--maroon);
    color: var(--maroon);
  }
  .btn-outline-strong:hover {
    background: var(--maroon);
    color: var(--beige);
  }

  .btn-outline-soft {
    border-color: var(--beige-deep);
    color: var(--ink);
  }
  .btn-outline-soft:hover {
    border-color: var(--maroon-soft);
    color: var(--maroon-soft);
  }
</style>
