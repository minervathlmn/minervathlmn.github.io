---
const items = [
  { num: '01', title: 'About Me', desc: 'My story & background', href: '/about' },
  { num: '02', title: 'Previous Projects', desc: "What I've been building", href: '/projects' },
  { num: '03', title: 'My Resume', desc: 'Download my CV', href: '/resume' },
];
---

<section class="links-grid">
  {items.map((item) => (
    <a class="card" href={item.href}>
      <span class="num">{item.num}</span>
      <span class="title">{item.title}</span>
      <span class="desc">{item.desc}</span>
    </a>
  ))}
</section>

<style>
  .links-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--beige-deep);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .card {
    padding: clamp(1.75rem, 4vw, 2.5rem) var(--section-pad);
    border-right: 1px solid var(--beige-deep);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background-color 0.15s ease;
  }

  .card:last-child {
    border-right: none;
  }

  .card:hover {
    background: var(--beige-deep);
  }

  .num {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--maroon-soft);
  }

  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--maroon);
  }

  .desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--ink);
    opacity: 0.7;
  }

  @media (max-width: 720px) {
    .links-grid {
      grid-template-columns: 1fr;
    }
    .card {
      border-right: none;
      border-bottom: 1px solid var(--beige-deep);
    }
    .card:last-child {
      border-bottom: none;
    }
  }
</style>
